# Shared secret used to sign and verify voucher tokens. MUST match the value
# you paste into the Shopify notification template (see README → Snippet).
# Generate one with: openssl rand -hex 32
TOKEN_SECRET=

# Postgres connection string. On Vercel this is auto-injected by the
# Vercel Postgres integration. Locally, point at any Postgres instance.
POSTGRES_URL=

# Public base URL of this deployment (no trailing slash). Used by the QR
# endpoint to build the redeem URL it encodes.
BASE_URL=http://localhost:3000

# Partner store PINs, comma-separated as store:pin
# The matched store name is recorded on the redemption row.
PARTNER_PINS=storeA:1234,storeB:5678
